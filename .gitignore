# Secrets & local config — never commit
.env
.ssh/*
!.ssh/.gitkeep

# Editor
.vscode/

# Runtime state (keep the dirs, drop the contents)
data/*
!data/.gitkeep
logs/*
!logs/.gitkeep

# Bundled DB host bind mounts (Neo4j / PostgreSQL data + logs)
neo4j_data/
postgres_data/
postgres_logs/

# Misc
*.bak
__pycache__/
*.pyc

.dockerignore
.claude
