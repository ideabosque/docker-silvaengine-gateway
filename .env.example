# =============================================================================
# SilvaEngine Gateway — container environment (TEMPLATE)
# =============================================================================
# Copy to .env and fill in real values:   cp .env.example .env
# .env is gitignored; this template is committed. NEVER put real secrets here.
#
# docker-compose reads CONTAINER_PORT / GATEWAY_PORT for host port mapping and
# feeds the rest to the gateway, which forwards module settings (AWS, Neo4j,
# LLM, MCP) to each engine's Config.initialize().
# =============================================================================

# ── Engine source mount (REQUIRED) ───────────────────────────────────────────
# Host path (relative to this compose file, or absolute) to the silvaengine
# source repos. The engine modules are NOT installed in the image — they run
# from this mount (/app/src, via PYTHONPATH). The tree is mounted read-only;
# only knowledge_graph_engine / rfq_engine / mcp_daemon_engine are importable
# (see PYTHONPATH in docker-compose.yml). Edit locally + restart, no rebuild.
SILVAENGINE_SRC=../silvaengine
# Container PYTHONPATH — engine repo roots under /app/src that are importable.
# Only these engine modules are exposed from the mounted source tree. Add/remove
# entries (colon-separated) to change which engines run from source.
# ai_agent_core_engine loads agent handlers dynamically (get_ai_agent_handler),
# so the handler packages it uses must be on the path too (run from the mount).
PYTHONPATH=/app/src/knowledge_graph_engine:/app/src/rfq_engine:/app/src/mcp_daemon_engine:/app/src/ai_agent_core_engine:/app/src/ai_agent_handler:/app/src/openai_completions_agent_handler

# ── Port mapping ─────────────────────────────────────────────────────────────
# GATEWAY_PORT is the in-container bind port. If MCP tool packages call back into
# the gateway (gateway_base_url stored in DynamoDB, e.g. http://localhost:8765),
# this MUST match that port. Otherwise 8765 is the conventional default.
CONTAINER_PORT=8765                  # host port published by docker-compose
GATEWAY_PORT=8765                    # in-container uvicorn bind port
GATEWAY_HOST=0.0.0.0
GATEWAY_WORKERS=1                    # >1 requires shared task/rate/SSE backends

# ── Performance tuning ───────────────────────────────────────────────────────
# Thread pool size for synchronous dispatch execution (WebSocket handlers, etc.)
GATEWAY_DISPATCH_WORKERS=32

# ── Auth ─────────────────────────────────────────────────────────────────────
GATEWAY_AUTH_PROVIDER=local          # local | cognito
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXP=15                  # token lifetime (minutes)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
# ADMIN_STATIC_TOKEN=                 # optional pre-minted permanent admin token

# Local user file (optional). Drop users.json into ./data and uncomment to use:
# LOCAL_USER_FILE=/app/data/users.json

# ── AWS Cognito (only when GATEWAY_AUTH_PROVIDER=cognito) ────────────────────
# COGNITO_USER_POOL_ID=
# COGNITO_APP_CLIENT_ID=
# COGNITO_APP_SECRET=
# COGNITO_JWKS_URL=

# ── Route manifest ───────────────────────────────────────────────────────────
# Custom manifest mounted at ./data/routes.yaml (-> /app/data/routes.yaml),
# registering all three modules (GraphQL + REST + MCP + SSE).
# NOTE: if this path is set but the file is missing, the gateway falls back to
# the built-in KGE-only default (not the packaged routes.yaml). Keep the mount.
GATEWAY_ROUTES_CONFIG_PATH=/app/data/routes.yaml

# ── Shared-store backends (required when GATEWAY_WORKERS > 1) ─────────────────
GATEWAY_TASK_BACKEND=memory          # memory | dynamodb
GATEWAY_TASK_TTL=3600
GATEWAY_RATE_LIMIT_BACKEND=memory    # memory | dynamodb
GATEWAY_RATE_LIMIT=500
GATEWAY_RATE_WINDOW=60

# ── Tenant ───────────────────────────────────────────────────────────────────
endpoint_id=gpt
part_id=nestaging

# ── DynamoDB / AWS (shared across KGE, AI RFQ, MCP modules) ──────────────────
initialize_tables=1
# Lowercase: SilvaEngine setting-dict convention (forwarded to module Configs).
region_name=us-west-2
aws_access_key_id=
aws_secret_access_key=
# Uppercase: standard boto3/pynamodb credential chain. Required in-container —
# there's no ~/.aws/credentials, so DynamoDB access (pynamodb) needs these.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-west-2

# ── Neo4j (Knowledge Graph Engine — external container) ───────────────────────
# The gateway runs in a container, so localhost won't reach a host/other-container
# Neo4j. Use host.docker.internal (Docker Desktop) or the Neo4j service name if
# you attach this stack to its compose network (see docker-compose.yml).
neo4j_uri=bolt://host.docker.internal:7687
neo4j_username=neo4j
neo4j_password=change-me
neo4j_database=neo4j

# ── LLM ──────────────────────────────────────────────────────────────────────
llm_type=openai
llm_name=gpt-4o
openai_api_key=
# anthropic_api_key=
embedding_model=text-embedding-3-small
cache_enabled=0

# ── Dual-Backend Selection (forwarded to all module Configs) ─────────────────
# db_backend: "dynamodb" (default) or "postgresql"
# When "postgresql", PG_* keys below are used and DynamoDB table creation is
# skipped. Neo4j is always required regardless of backend.
# AWS credentials are still needed for S3 file parsing.
db_backend=postgresql

# PostgreSQL connection (used when db_backend=postgresql)
# PG_HOST must be host.docker.internal when the gateway runs in a Docker
# container and PostgreSQL runs on the host. localhost inside a container
# refers to the container itself, not the host machine.
PG_HOST=host.docker.internal
PG_PORT=5432
PG_USER=silvaengine
PG_PASSWORD=silvaengine
PG_DB=silvaengine
# Per-module PG table prefixes — each module gets its own prefix to avoid
# table-name collisions in shared databases.
KGE_PG_TABLE_PREFIX=kge_
RFQ_PG_TABLE_PREFIX=rfq_

# ── MCP Daemon Engine (driven through the gateway) ───────────────────────────
MCP_TRANSPORT=sse                    # served over HTTP/SSE inside FastAPI
FUNCT_BUCKET_NAME=                   # S3 bucket for MCP tool packages
FUNCT_ZIP_PATH=/app/data/funct_zips  # local zip staging (under mounted ./data)
FUNCT_EXTRACT_PATH=/app/data/functs  # package extraction (must be importable)

# ── AI Agent Core Engine — internal MCP ──────────────────────────────────────
# Forwarded to ai_agent_core_engine as `internal_mcp`. REQUIRED if any agent's
# mcp_server_uuids reference the internal MCP (else ask_model fails with
# "Internal MCP (None) is not configured correctly").
#   internal_mcp_base_url : HOST ONLY of this gateway (loopback in-container);
#                           it appends /{endpoint_id}/mcp itself. Match GATEWAY_PORT.
#   bearer_token          : used directly if set; otherwise the gateway mints a
#                           local JWT from internal_mcp_token_username/password.
#   x-api-key             : header sent on internal MCP calls.
# Leave internal_mcp_base_url unset to disable.
# internal_mcp_base_url=http://localhost:8000
# internal_mcp_bearer_token=
# internal_mcp_token_username=admin
# internal_mcp_token_password=change-me
# x-api-key=
